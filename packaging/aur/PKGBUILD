# Maintainer: Chris Snell <chris@chrissnell.com>
pkgname=purtypics
pkgver=VERSION
pkgrel=1
pkgdesc='A fast, modern static photo gallery generator'
arch=('x86_64' 'aarch64')
url='https://github.com/chrissnell/purtypics'
license=('MIT')
depends=('glibc')
makedepends=('go')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/chrissnell/purtypics/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
    cd "${pkgname}-${pkgver}"
    export CGO_ENABLED=0
    go build -ldflags "-s -w -X main.version=${pkgver}" -o ${pkgname} .
}

package() {
    cd "${pkgname}-${pkgver}"
    install -Dm755 "${pkgname}" "${pkgdir}/usr/bin/${pkgname}"
    install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"

    # Install themes
    install -dm755 "${pkgdir}/usr/share/purtypics/themes"
    cp -r pkg/gallery/assets/themes/* "${pkgdir}/usr/share/purtypics/themes/"
}
